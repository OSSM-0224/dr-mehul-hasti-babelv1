{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "types": ["vite/client"],
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/lib/utils": [
        "./src/utils/cn.ts"
      ],
      "@/utils/cn": [
        "./src/utils/cn.ts"
      ],
      "@/components/ui/*": [
        "./src/components/ui/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
